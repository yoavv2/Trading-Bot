POSTGRES_DB=trading_platform
POSTGRES_USER=trading_platform
POSTGRES_PASSWORD=trading_platform
TRADING_PLATFORM_APP__ENVIRONMENT=local
TRADING_PLATFORM_API__PORT=8000
TRADING_PLATFORM_LOGGING__LEVEL=INFO
TRADING_PLATFORM_DATABASE__HOST=localhost
TRADING_PLATFORM_DATABASE__PORT=5432

# Polygon.io market-data provider — required for live bar ingestion and metadata refresh.
# Get your API key at https://polygon.io/dashboard
TRADING_PLATFORM_MARKET_DATA__POLYGON__API_KEY=your_polygon_api_key_here

# Exchange calendar (default: XNYS for NYSE — covers all configured US equity symbols)
# TRADING_PLATFORM_MARKET_DATA__CALENDAR__EXCHANGE=XNYS
