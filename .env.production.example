# Production/hosted backend env (FREE-TIER CHECKPOINT) — DO NOT COMMIT REAL VALUES.
#
# These drive both the FastAPI API and Alembic migrations (settings read the
# TRADING_PLATFORM_ prefix). On Render, enter these in the dashboard when the
# Blueprint prompts for the `sync: false` vars — do not put secrets in git.

# --- Database: Neon free Postgres (production-reachable, SSL by default) ---
# From your Neon project's connection details. Use the DIRECT host (not -pooler
# is fine for a single long-lived Render container). Neon requires TLS; the
# psycopg default sslmode=prefer negotiates it automatically — no extra config.
TRADING_PLATFORM_DATABASE__HOST=ep-xxxx-xxxx.us-west-2.aws.neon.tech
TRADING_PLATFORM_DATABASE__PORT=5432
TRADING_PLATFORM_DATABASE__NAME=neondb
TRADING_PLATFORM_DATABASE__USER=neondb_owner
TRADING_PLATFORM_DATABASE__PASSWORD=your_neon_password_here

# Honest environment label for the hosted API.
TRADING_PLATFORM_APP__ENVIRONMENT=staging

# --- Worker-only credentials (NOT needed by the API) ---
# The read-only API never instantiates a market-data or broker client, so it
# deploys and runs without these. They are only consumed by the worker at
# ingest/execution time, which is NOT deployed in this checkpoint. Set them only
# where the worker actually runs (Docker/CLI).
# TRADING_PLATFORM_MARKET_DATA__POLYGON__API_KEY=your_polygon_api_key_here
# TRADING_PLATFORM_BROKER__ALPACA__API_KEY=your_alpaca_api_key_here
# TRADING_PLATFORM_BROKER__ALPACA__API_SECRET=your_alpaca_api_secret_here
